.models/
*.onnx
*.bin

# ── Temp files ─────────────────────────────────────────────────────
.tmp/badge.png
.tmp/cap_*.png
.tmp/images/
.tmp/reels/
.tmp/*/reels/
.tmp/disciplinefuel/images/
.tmp/disciplinefuel/canva/
.tmp/disciplinefuel/canva_token.json
.tmp/yt_transcript*
.tmp/*.mp4
